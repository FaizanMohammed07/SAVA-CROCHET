#                          👁️ VISITOR TRACKING
###############################################################################

### Track Product View (anonymous)
POST {{baseUrl}}/visitors/product-view
Content-Type: application/json

{
  "productId": "{{productId}}"
}

###

### Track Product View (authenticated)
POST {{baseUrl}}/visitors/product-view
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "productId": "{{productId}}"
}

###

### End Visitor Session
POST {{baseUrl}}/visitors/end-session
Content-Type: application/json

{}

###

### Track Conversion Event
POST {{baseUrl}}/visitors/conversion
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "type": "purchase",
  "orderId": "{{orderId}}"
}

###############################################################################
#                          🧪 EDGE CASES & ERROR TESTING
###############################################################################

### Login with wrong password (should return 401)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "savatest@example.com",
  "password": "WrongPassword123"
}

###

### Access protected route without token (should return 401)
GET {{baseUrl}}/users/profile

###

### Access admin route with user token (should return 403)
GET {{baseUrl}}/admin/users
Authorization: Bearer {{accessToken}}

###

### Get non-existent product (should return 404)
GET {{baseUrl}}/products/000000000000000000000000

###

### Register with invalid email (should return 400)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "firstName": "Bad",
  "lastName": "Email",
  "email": "not-an-email",
  "password": "Test@1234",
  "phone": "9876543210"
}

###

### Create order with empty cart (should return 400)
POST {{baseUrl}}/orders
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "shippingAddress": {
    "fullName": "Test",
    "phone": "9876543210",
    "addressLine1": "123 Test St",
    "city": "Mumbai",
    "state": "Maharashtra",
    "pincode": "400001"
  },
  "paymentMethod": "cod"
}

###

### Add to cart with invalid product ID (should return 404)
POST {{baseUrl}}/cart/items
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "productId": "000000000000000000000000",
  "quantity": 1
}

###############################################################################
#  📝 USAGE NOTES
#  
#  1. Start the server: `npm run dev` (from backend/)
