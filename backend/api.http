{
  "stock": 100
}

###############################################################################
#                          🔧 ADMIN — Reservations
###############################################################################

### Get All Reservations
GET {{baseUrl}}/admin/reservations?page=1&limit=10
Authorization: Bearer {{adminToken}}

###

### Get Reservations by Status
GET {{baseUrl}}/admin/reservations?status=pending&page=1&limit=10
Authorization: Bearer {{adminToken}}

###

### Update Reservation — Price Estimate
PATCH {{baseUrl}}/admin/reservations/{{reservationId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "price_estimated",
  "estimatedPrice": 1500,
  "estimatedCompletionDays": 14,
  "adminNotes": "Beautiful design! Will use premium cotton yarn.",
  "priority": "normal"
}

###

### Update Reservation — Approve
PATCH {{baseUrl}}/admin/reservations/{{reservationId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "approved",
  "adminNotes": "Customer accepted price. Starting production."
}

###

### Update Reservation — In Production
PATCH {{baseUrl}}/admin/reservations/{{reservationId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "in_production",
  "adminNotes": "Work started, 50% yarn done"
}

###

### Update Reservation — Completed
PATCH {{baseUrl}}/admin/reservations/{{reservationId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "completed",
  "adminNotes": "Finished! Ready for shipping."
}

###

### Update Reservation — Reject
PATCH {{baseUrl}}/admin/reservations/{{reservationId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "rejected",
  "rejectionReason": "Design too complex for the requested deadline"
}

###############################################################################
#                          🔧 ADMIN — Coupons
###############################################################################

### Create Coupon (Percentage)
POST {{baseUrl}}/admin/coupons
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "code": "SAVA20",
  "description": "20% off on all products",
  "discountType": "percentage",
  "discountValue": 20,
  "minOrderAmount": 500,
  "maxDiscount": 1000,
  "startDate": "2026-03-01",
  "endDate": "2026-12-31",
  "usageLimit": 500,
  "perUserLimit": 2,
  "isActive": true
}

###

### Create Coupon (Flat Discount)
POST {{baseUrl}}/admin/coupons
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "code": "FLAT200",
  "description": "Flat ₹200 off on orders above ₹999",
  "discountType": "flat",
  "discountValue": 200,
  "minOrderAmount": 999,
  "startDate": "2026-03-01",
  "endDate": "2026-06-30",
  "usageLimit": 100,
  "perUserLimit": 1,
  "isActive": true
}

###

### Get All Coupons
GET {{baseUrl}}/admin/coupons
Authorization: Bearer {{adminToken}}

###

### Update Coupon
PUT {{baseUrl}}/admin/coupons/{{couponId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "discountValue": 25,
  "endDate": "2027-03-31",
  "isActive": true
}

###

### Delete Coupon
DELETE {{baseUrl}}/admin/coupons/{{couponId}}
Authorization: Bearer {{adminToken}}

